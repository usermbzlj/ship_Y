# Server-only fixed LLM configuration. Leave empty to use
# config/llm.example.json, or provide a complete one-line JSON document.
LLM_CONFIG_JSON=

# Secrets are resolved by the server from these environment variable names.
# Never place actual keys in config/llm.example.json or browser code.
SHIP_CAPTAIN_LLM_API_KEY=
SHIP_NAVIGATION_LLM_API_KEY=
SHIP_ENGINEERING_LLM_API_KEY=
SHIP_LIFE_SUPPORT_LLM_API_KEY=
SHIP_MEDICAL_LLM_API_KEY=
SHIP_PASSENGER_AFFAIRS_LLM_API_KEY=
SHIP_SECURITY_LLM_API_KEY=
SHIP_PASSENGER_SERVICE_LLM_API_KEY=
